{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.{ts,tsx,js,jsx}", "src/main.{ts,tsx,js,jsx}"],
  "ignoreDependencies": [
    "jiti",
    "eslint-import-resolver-typescript",
    "tsconfig-paths"
  ],
  "ignorePatterns": [
    "**/*.generated.ts",
    "**/*.d.ts",
    "**/*.spec.{ts,tsx,js,jsx}",
    "**/*.test.{ts,tsx,js,jsx}",
    "**/*.e2e.{ts,tsx,js,jsx}",
    "**/__tests__/**",
    "**/tests/**",
    "**/test/**",
    "**/vitest.config.*",
    "**/jest.config.*",
    "./package.json"
  ],
  "duplicates": {
    "minOccurrences": 3,
    "ignore": [
      "**/lib/**",
      "**/legacy/**",
      "**/__generated__/**",
      "**/generated/**"
    ]
  },
  "rules": {
    "unused-dependencies": "warn",
    "unused-files": "warn",
    "unused-exports": "warn"
  }
}
