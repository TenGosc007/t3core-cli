{
  "name": "t3core-cli",
  "version": "1.5.0",
  "description": "Interactive Tic Tac Toe CLI — play in your terminal via npx t3core-cli",
  "main": "dist/index.js",
  "preferGlobal": true,
  "scripts": {
    "start": "node -r tsconfig-paths/register -r ts-node/register index.ts",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn index.ts",
    "build": "rm -rf dist && tsup",
    "build:watch": "tsup --watch",
    "lint": "eslint src tests vitest.config.mts",
    "ts:check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "fallow": "fallow health",
    "publish:dry": "npm run build && npm publish --dry-run",
    "release": "env -i HOME=$HOME PATH=$PATH bash scripts/release.sh"
  },
  "keywords": [
    "tic-tac-toe",
    "game",
    "typescript",
    "nodejs",
    "cli"
  ],
  "author": "tengosc",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TenGosc007/t3core-cli.git"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "t3core-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "fallow": "^2.87.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "t3core": "^1.5.0"
  }
}
