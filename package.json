{
  "name": "t3core-cli",
  "version": "1.1.4",
  "description": "tic tac toe core - tttc - t3c",
  "main": "dist/index.js",
  "scripts": {
    "start": "node -r tsconfig-paths/register -r ts-node/register index.ts",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn index.ts",
    "build": "tsc && tsc-alias && chmod +x dist/index.js",
    "test": "vitest",
    "lint": "eslint ./src/**/*.ts",
    "ts:check": "tsc --noEmit",
    "publish:dry": "npm run build && npm publish --dry-run",
    "release:tag": "env -i HOME=$HOME PATH=$PATH bash scripts/release.sh",
    "new:release": "env -i HOME=$HOME PATH=$PATH bash scripts/publish-release.sh"
  },
  "keywords": [
    "tic-tac-toe",
    "game",
    "typescript",
    "nodejs"
  ],
  "author": "tengosc",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TenGosc007/t3core.git"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=16.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/src/core/index.d.ts",
      "require": "./dist/src/core/index.js",
      "default": "./dist/src/core/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/src/core/index.d.ts",
  "bin": {
    "tic-tac-toe-core": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4"
  }
}
