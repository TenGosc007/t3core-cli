{
  "name": "t3core-cli",
  "version": "1.5.0",
  "description": "Interactive Tic Tac Toe CLI — play in your terminal via npx t3core-cli",
  "main": "dist/index.js",
  "preferGlobal": true,
  "scripts": {
    "start": "tsx index.ts",
    "dev": "tsx watch index.ts",
    "build": "rm -rf dist && tsup",
    "build:watch": "tsup --watch",
    "lint": "eslint src tests vitest.config.mts",
    "ts:check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "fallow": "fallow health --coverage coverage/coverage-final.json",
    "publish:dry": "npm run build && npm publish --dry-run",
    "release": "env -i HOME=$HOME PATH=$PATH bash scripts/release.sh",
    "dev:ink": "tsup --no-minify --sourcemap && trap 'kill %1' EXIT; tsup --watch --no-minify --sourcemap & node --watch dist/index.js",
    "lint:tsx": "eslint src/**/*.tsx tests/**/*.tsx",
    "build:dev": "tsup --no-minify --sourcemap"
  },
  "keywords": [
    "tic-tac-toe",
    "game",
    "typescript",
    "nodejs",
    "cli"
  ],
  "author": "tengosc",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TenGosc007/t3core-cli.git"
  },
  "type": "module",
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "t3core-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fallow": "^2.87.0",
    "globals": "^17.6.0",
    "ink-testing-library": "^4.0.0",
    "jiti": "^2.6.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "conf": "^15.1.0",
    "ink": "^7.1.0",
    "meow": "^14.1.0",
    "react": "^19.2.7",
    "react-router": "^8.0.1",
    "t3core": "^1.5.0",
    "zustand": "^5.0.14"
  }
}
